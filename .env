# ==========================================
# 仓库监控系统配置文件 (Warehouse Monitoring System)
# ==========================================

# ==========================================
# 1. 模块: FaceCapture (人脸识别与抓拍)
# ==========================================
# 人脸识别服务接口地址 (CompreFace Direct API)
FACE_API_URL=http://192.168.13.199:8001/api/v1/recognition/recognize
FACE_API_KEY=dd3b6146-c58e-47ab-9aa1-8abb5bdad7d8
# 同一个人脸调用识别接口的冷却时间（秒），防止短时间内重复识别同一人
FACE_API_INTERVAL=2.0
# 人脸检测置信度阈值 (0.0-1.0)，越高越严格
FACE_CONFIDENCE_THRESHOLD=0.55

# --- 抓拍与追踪策略 ---
# 同一个人脸识别上报的冷却时间（秒）。在此时间内同一用户不会被重复上报
FACE_COOLDOWN_DURATION=600.0
# 游客识别缓冲时间（秒）。如果在此期间检测到注册用户，则优先上报用户并丢弃游客记录
FACE_VISITOR_BUFFER_DURATION=10.0

# 判定为“人脸进入”所需的最小持续检测时间（秒）。设为 0.1 表示几乎瞬间触发
FACE_MIN_DETECTION_DURATION=0.1
# 人脸在画面中的最小面积占比 (0.0-1.0)。设为 0.0 表示不限制大小，远程小脸也会捕获
FACE_MIN_AREA_RATIO=0.0
# 人脸消失后，保持该追踪会话的超时时间（秒）
FACE_TRACKING_TIMEOUT=5.0
# 在持续追踪过程中，每隔多少秒进行一次识别上报
FACE_REPORT_INTERVAL=1.0

# --- 图像质量控制 ---
# 抓拍窗口时间（秒）。在此时间内会挑选一张质量最好的脸发送
FACE_CAPTURE_WINDOW=0.5
# 立即抓拍的质量阈值 (0.0-1.0)。如果检测到质量超过此值，则不等待窗口期直接发送
FACE_MIN_QUALITY_THRESHOLD=0.5
# 最低可接受的质量分数。如果窗口期结束仍未达到此分数，则放弃本次抓拍
FACE_MIN_ACCEPT_THRESHOLD=0.1

# ==========================================
# 2. 模块: TimeCapture (时间/人员离开检测)
# ==========================================
# 人脸抓拍相机的 RTSP 地址 (主)
RTSP_URL_TIMECAPTURE=rtsp://admin:Lzwc%402025.@192.168.15.119:554/Streaming/Channels/101
# 备用视频流地址 (当主流失败时尝试)
RTSP_URL_BACKUP_BASE=rtsp://admin:Lzwc%402025.@192.168.15.119:554/Streaming/tracks/101
# 字符识别/行为检测置信度阈值
TIME_CONFIDENCE_THRESHOLD=0.6
# 判定人员离开的超时时间（秒）
TIME_PERSON_TIMEOUT=12.0

# ==========================================
# 3. 模块: AssetScanning (资产扫描/RFID)
# ==========================================
# RFID 读写器的连接串口地址
RFID_CONN_STR=/dev/ttyACM0
# RFID 功率设置 (单位: centidBm)。例如 3000 代表 30.00 dBm (最大值)
RFID_POWER=3000

# ==========================================
# 4. 模块: Common / ToAgent (公共配置与Agent)
# ==========================================
# --- Agent 集成 ---
# 消息通知/Webhook 调用的基础地址
AGENT_BASE_URL=http://192.168.11.24:8082/api/system/employee/webhook/invoke
# 工作流执行地址
AGENT_WORKFLOW_URL=http://192.168.11.24:8088/open/workflow/execute
# 工作流 API Key
AGENT_API_KEY=wf_6356a9907849423ba0d3c5510c60f64a
# 工作流 ID
AGENT_WORKFLOW_ID=2027306314434215938
# 默认员工 ID (用于上报)
EMPLOYEE_ID=2027303292526264322
# 默认用户 ID (用于上报)
USER_ID=748

# --- 文件存储 (MinIO) ---
# 图片/文件上传服务的接口地址 (MinIO)
MINIO_UPLOAD_URL=http://192.168.11.24:8082/api/system/file/upload
