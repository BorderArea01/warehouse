# RTSP 视频流配置
# 人脸抓拍相机的 RTSP 地址
RTSP_URL_TIMECAPTURE=rtsp://admin:Lzwc%402025.@192.168.15.119:554/Streaming/Channels/101
# 备用/基础视频流地址
RTSP_URL_BACKUP_BASE=rtsp://admin:Lzwc%402025.@192.168.15.119:554/Streaming/tracks/101

# 人脸识别 API 配置
# 人脸识别服务接口地址
FACE_API_URL=http://192.168.11.24:8088/system/visitorRecord/recognizeFace
# 人脸检测置信度阈值 (0.0-1.0)，越高越严格
FACE_CONFIDENCE_THRESHOLD=0.4

# 人脸捕获逻辑微调
# 判定为“人脸进入”所需的最小持续检测时间（秒）。设为 0.1 表示几乎瞬间触发
FACE_MIN_DETECTION_DURATION=0.1
# 人脸在画面中的最小面积占比 (0.0-1.0)。设为 0.0 表示不限制大小，远程小脸也会捕获
FACE_MIN_AREA_RATIO=0.0
# 人脸消失后，保持该追踪会话的超时时间（秒）
FACE_TRACKING_TIMEOUT=5.0
# 在持续追踪过程中，每隔多少秒进行一次识别上报
FACE_REPORT_INTERVAL=0.3

# 人脸质量与抓拍策略
# 抓拍窗口时间（秒）。在此时间内会挑选一张质量最好的脸发送
FACE_CAPTURE_WINDOW=0.5
# 立即抓拍的质量阈值 (0.0-1.0)。如果检测到质量超过此值，则不等待窗口期直接发送
FACE_MIN_QUALITY_THRESHOLD=0.4
# 最低可接受的质量分数。如果窗口期结束仍未达到此分数，则放弃本次抓拍
FACE_MIN_ACCEPT_THRESHOLD=0.1
# 同一个人脸调用识别接口的冷却时间（秒），防止短时间内重复识别同一人
FACE_API_INTERVAL=5.0

# 时间/字符识别配置 (Time Capture)
# 字符识别置信度阈值
TIME_CONFIDENCE_THRESHOLD=0.6
# 判定人员离开的超时时间（秒）
TIME_PERSON_TIMEOUT=12.0

# Agent 代理集成配置
# 消息通知/Webhook 调用的基础地址
AGENT_BASE_URL=http://192.168.11.24:8082/api/system/employee/webhook/invoke
# 员工 ID
EMPLOYEE_ID=2027303292526264322
# 用户 ID
USER_ID=748

# MinIO 文件上传配置
# 图片/文件上传服务的接口地址
MINIO_UPLOAD_URL=http://192.168.11.24:8082/api/system/file/upload

# 资产扫描 (RFID) 配置
# RFID 读写器的连接串口地址
RFID_CONN_STR=/dev/ttyACM2
# RFID 功率设置 (单位: centidBm)。例如 3000 代表 30.00 dBm (最大值)
RFID_POWER=3000
